    <mxCell id="3" value="Endpoint analizado:&lt;br/&gt;&lt;b&gt;GET /content/{id}/visibility?country=CL&amp;age=25&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Consulta si un contenido es visible para un espectador según su país y edad. Evalúa el estado del contenido y sus restricciones activas." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=6;" vertex="1" parent="1">
      <mxGeometry x="800" y="55" width="280" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="4" value="&lt;b&gt;Decisión 15:&lt;/b&gt; País y edad los aporta &lt;b&gt;quien llama&lt;/b&gt;. Catálogo no busca el perfil del espectador por su cuenta — la identidad del usuario es una plataforma compartida fuera de este contexto (sección 2.2 del enunciado).&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Decisión 2:&lt;/b&gt; Las restricciones se evalúan aparte, no como parte del campo status del contenido." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;" vertex="1" parent="1">
