    <mxCell id="3" value="Endpoint analizado:&lt;br/&gt;&lt;b&gt;POST /live-streams/{id}/convert-to-vod&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Genera un video on-demand (VOD) a partir de una transmisión en vivo finalizada. El live debe estar en estado &lt;b&gt;ended&lt;/b&gt; para poder llamar a este endpoint." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingRight=6;" vertex="1" parent="1">
      <mxGeometry x="800" y="55" width="280" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="4" value="&lt;b&gt;Decisión de diseño (Decisión 10):&lt;/b&gt;&lt;br/&gt;Esta acción es &lt;b&gt;explícita&lt;/b&gt;, no automática. El enunciado usa &quot;debe &lt;i&gt;poder&lt;/i&gt; generar&quot;, no &quot;debe generar automáticamente&quot; — el creador decide si convierte el live a VOD, el sistema no lo hace solo." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;" vertex="1" parent="1">
