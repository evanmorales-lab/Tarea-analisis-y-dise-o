                  }
                }
              }
            }
          },
          "404": {
            "description": "Campana no encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "advertiser_oauth": [
              "manage:campaigns",
              "read:reports"
            ]
          }
        ]
      }
    },
    "/integration/emitted-events": {
      "get": {
        "tags": [
          "integracion"
        ],
        "operationId": "listEmittedEvents",
        "summary": "Listar los eventos emitidos hacia otros contextos.",
        "description": "Evidencia de integracion. Copiar el payload de 'AdRevenueGenerated' y enviarlo a POST /integration/ad-revenue-confirmed del Contexto 5.",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Operacion exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IntegrationEvent"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "advertiser_oauth": [
              "manage:campaigns",
              "read:reports"
            ]
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CampaignObjective": {
        "type": "string",
        "enum": [
          "awareness",
          "traffic",
          "conversions"
        ]
      },
      "CampaignStatus": {
        "type": "string",
        "enum": [
          "draft",
          "active",
          "paused",
          "ended"
        ]
      },
      "CreativeType": {
        "type": "string",
        "enum": [
          "video",
          "display"
        ]
      },
      "CreativeValidationStatus": {
        "type": "string",
        "enum": [
          "pending",
          "approved",
          "rejected"
        ]
      },
      "AdFormat": {
        "type": "string",
        "enum": [
          "preroll",
          "midroll",
          "display"
        ]
      },
      "AdDecisionOutcome": {
        "type": "string",
        "enum": [
          "served",
          "no_ad"
        ]
      },
      "BillingInfo": {
        "type": "object",
        "required": [
          "legalName",
          "taxId",
          "country"
        ],
        "properties": {
          "legalName": {
            "type": "string"
          },
          "taxId": {
            "type": "string"
          },
          "country": {
            "type": "string",
            "example": "CL"
          },
          "billingEmail": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Advertiser": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "example": "Acme Corp"
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "billingInfo": {
            "$ref": "#/components/schemas/BillingInfo"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "required": [
          "advertiserId",
          "name",
          "objective",
          "budgetTotal",
          "startDate",
          "endDate"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "advertiserId": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "objective": {
            "$ref": "#/components/schemas/CampaignObjective"
          },
          "budgetTotal": {
            "type": "number",
            "format": "double",
            "example": 1000.0
          },
          "budgetSpent": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "currency": {
            "type": "string",
            "default": "USD"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "$ref": "#/components/schemas/CampaignStatus"
          }
        }
      },
      "Creative": {
        "type": "object",
        "required": [
          "type",
          "url"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "campaignId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "type": {
            "$ref": "#/components/schemas/CreativeType"
          },
          "url": {
            "type": "string",
            "example": "https://cdn.example/creo.mp4"
          },
          "validationStatus": {
            "readOnly": true,
            "$ref": "#/components/schemas/CreativeValidationStatus"
          }
        }
      },
      "Targeting": {
        "type": "object",
        "properties": {
          "campaignId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "CL",
              "AR"
            ]
          },
          "minAge": {
            "type": "integer",
            "nullable": true
          },
          "maxAge": {
            "type": "integer",
            "nullable": true
          },
          "interests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "contentCategories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "InventoryEstimate": {
        "type": "object",
        "properties": {
          "estimatedImpressions": {
            "type": "integer",
            "format": "int64"
          },
          "estimatedReach": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "EligibilityResult": {
        "type": "object",
        "properties": {
          "videoId": {
            "type": "integer",
            "format": "int64"
          },
          "eligible": {
            "type": "boolean"
          },
          "reason": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "AdDecisionRequest": {
        "type": "object",
        "required": [
          "videoId",
          "format"
        ],
        "properties": {
          "videoId": {
            "type": "integer",
            "format": "int64"
          },
          "format": {
            "$ref": "#/components/schemas/AdFormat"
          },
          "viewerCountry": {
            "type": "string",
            "nullable": true,
            "example": "CL"
          },
          "viewerAge": {
            "type": "integer",
            "nullable": true,
            "example": 25
          },
          "contentCategory": {
            "type": "string",
            "nullable": true,
            "example": "music"
          }
        }
      },
      "AdDecisionResult": {
        "type": "object",
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/AdDecisionOutcome"
          },
          "campaignId": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "creativeId": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "format": {
            "nullable": true,
            "$ref": "#/components/schemas/AdFormat"
          },
          "reason": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Impression": {
        "type": "object",
        "required": [
          "campaignId",
          "creativeId",
          "videoId",
          "channelId",
          "format"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "campaignId": {
            "type": "integer",
            "format": "int64"
          },
          "creativeId": {
            "type": "integer",
            "format": "int64"
          },
          "videoId": {
            "type": "integer",
            "format": "int64"
          },
          "channelId": {
            "type": "integer",
            "format": "int64"
          },
          "format": {
            "$ref": "#/components/schemas/AdFormat"
          },
          "cost": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "currency": {
            "type": "string",
            "readOnly": true
          },
          "billable": {
            "type": "boolean",
            "example": true
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        }
      },
      "Click": {
        "type": "object",
        "required": [
          "impressionId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "impressionId": {
            "type": "integer",
            "format": "int64"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        }
      },
      "Skip": {
        "type": "object",
        "required": [
          "impressionId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "impressionId": {
            "type": "integer",
            "format": "int64"
          },
          "skippedAtSeconds": {
            "type": "integer",
            "example": 5
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        }
      },
      "CampaignMetrics": {
        "type": "object",
        "properties": {
          "campaignId": {
            "type": "integer",
            "format": "int64"
          },
          "impressions": {
            "type": "integer",
            "format": "int64"
          },
          "clicks": {
            "type": "integer",
            "format": "int64"
          },
          "ctr": {
            "type": "number",
            "format": "double"
          },
          "cpm": {
            "type": "number",
            "format": "double"
          },
          "spend": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "campaignId": {
            "type": "integer",
            "format": "int64"
          },
          "advertiserId": {
            "type": "integer",
            "format": "int64"
          },
          "periodFrom": {
            "type": "string",
            "format": "date-time"
          },
          "periodTo": {
            "type": "string",
            "format": "date-time"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "AdRevenueGeneratedEvent": {
        "type": "object",
        "required": [
          "eventId",
          "channelId",
          "videoId",
          "campaignId",
          "billableAmount"
        ],
        "properties": {
          "eventId": {
            "type": "string",
            "example": "evt-ad-1"
          },
          "channelId": {
            "type": "integer",
            "format": "int64"
          },
          "videoId": {
            "type": "integer",
            "format": "int64"
          },
          "campaignId": {
            "type": "integer",
            "format": "int64"
          },
          "billableAmount": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string",
            "default": "USD"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "description": "Contrato de evento compartido con el Contexto 5 (Monetizacion)."
      },
      "IntegrationEvent": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          },
          "emittedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "advertiser_oauth": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://accounts.example.com/oauth/token",
            "scopes": {
              "manage:campaigns": "crear y administrar campanas",
              "read:reports": "leer metricas e invoices"
            }
          }
        }
      },
      "api_key": {
        "type": "apiKey",
        "name": "api_key",
        "in": "header"
      }
    }
  }
}