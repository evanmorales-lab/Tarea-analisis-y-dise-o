    "/playlists/{playlistId}/items": {
      "parameters": [
        {
          "$ref": "#/components/parameters/PlaylistIdParam"
        }
      ],
      "post": {
        "operationId": "addPlaylistItem",
        "tags": [
          "Playlists"
        ],
        "summary": "Agregar un contenido a la playlist",
        "description": "Requiere rol `creator`, dueño de la playlist.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaylistItemAddInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ítem agregado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Playlist"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "reorderPlaylistItems",
        "tags": [
          "Playlists"
        ],
        "summary": "Reordenar los ítems de la playlist",
        "description": "Reemplaza el orden completo en una sola operación (en vez de mover ítems de a\nuno), mandando la lista completa de `contentId` en el nuevo orden. Requiere rol\n`creator`, dueño de la playlist.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaylistReorderInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Playlist reordenada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Playlist"
                }
              }
            }
          }
        }
      }
    },
    "/playlists/{playlistId}/items/{contentId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/PlaylistIdParam"
        },
        {
          "$ref": "#/components/parameters/ContentIdParam"
        }
      ],
      "delete": {
        "operationId": "removePlaylistItem",
        "tags": [
          "Playlists"
        ],
        "summary": "Quitar un contenido de la playlist",
        "description": "Acá sí se usa DELETE: quitar un ítem es borrar de verdad esa relación de\npertenencia (el contenido en sí no se borra). Requiere rol `creator`, dueño de\nla playlist.\n",
        "responses": {
          "204": {
            "description": "Ítem quitado"
          }
        }
      }
    },
