            ]
          }
        }
      },
      "Restriction": {
        "type": "object",
        "description": "Registro de una restricción aplicada. Nunca se borra: levantarla solo completa liftedAt, conservando el historial (RF-C6, viñeta 2).\n",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "contentId": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "type": "string",
            "enum": [
              "minimum_age",
              "geo_block",
              "monetization_limit"
            ]
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "minAge": 18
            }
          },
          "appliedAt": {
            "type": "string",
            "format": "date-time"
          },
          "liftedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "RestrictionCreateInput": {
        "type": "object",
        "required": [
          "type",
          "details"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "minimum_age",
              "geo_block",
              "monetization_limit"
            ]
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "blockedCountries": [
                "XX",
                "YY"
              ]
            }
          }
        }
      },
      "AssetReadyForPublishingEvent": {
        "type": "object",
        "description": "Evento consumido desde el bounded context de Publicación y distribución de contenido. Habilita la creación de un borrador de catálogo para ese asset.\n",
        "properties": {
          "eventType": {
            "type": "string",
            "enum": [
              "AssetReadyForPublishing"
            ]
          },
          "videoAssetId": {
            "type": "string",
            "format": "uuid"
          },
          "creatorId": {
            "type": "string",
            "format": "uuid"
          },
          "durationSeconds": {
            "type": "number"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
