        "description": "No surge de una viñeta explícita; es necesaria para poder navegar hacia cualquier playlist.",
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de playlists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedPlaylists"
                }
              }
            }
          }
        }
      }
