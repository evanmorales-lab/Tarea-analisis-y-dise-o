        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChannelCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Canal creado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Channel"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/channels/{channelId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ChannelIdParam"
        }
      ],
      "get": {
        "operationId": "getChannel",
        "tags": [
          "Channels"
        ],
        "summary": "Consultar la información pública del canal",
        "responses": {
          "200": {
            "description": "Detalle del canal",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Channel"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "operationId": "updateChannel",
        "tags": [
          "Channels"
        ],
        "summary": "Actualizar nombre, descripción o imagen del canal",
        "description": "Requiere rol `creator`, dueño del canal. Actualización parcial.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChannelUpdateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Canal actualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Channel"
                }
              }
            }
          }
        }
      }
    },
    "/channels/{channelId}/content": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ChannelIdParam"
        }
      ],
      "get": {
        "operationId": "listChannelContent",
        "tags": [
          "Channels"
        ],
        "summary": "Listar el contenido publicado de un canal",
        "description": "Puerta pública (cualquiera puede consultarla). Solo devuelve contenido en\nestado `published` — nunca borradores, que son privados del creador.\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de contenido publicado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedCatalogItems"
                }
              }
            }
          }
        }
      }
    },
    "/content": {
      "x-rf-section": "RF-C2 — Creación y edición editorial",
      "post": {
        "operationId": "createCatalogItem",
        "tags": [
          "Content"
        ],
        "summary": "Vincular un asset técnico con su metadata editorial",
        "description": "Crea el ítem de catálogo en estado `draft` (RF-C2, viñetas 1, 2 y 3). Requiere\nrol `creator`, dueño del `channelId` indicado.\n\n**Validación importante:** el `videoAssetId` debe corresponder a un asset que\nCatálogo ya recibió como técnicamente listo (evento `AssetReadyForPublishing`\nconsumido desde Publicación). Si todavía no se recibió ese evento, se rechaza\ncon `409 ASSET_NOT_READY`. Esta validación se hace contra el registro interno\nde eventos recibidos, no contra una consulta síncrona a Publicación — así\nCatálogo no depende de que Publicación esté disponible en el momento.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogItemCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contenido creado en borrador",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogItem"
                }
              }
            }
          },
          "409": {
            "description": "El videoAssetId aún no fue notificado como listo por Publicación",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/content/{contentId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        }
      ],
      "get": {
        "operationId": "getCatalogItem",
        "tags": [
          "Content"
        ],
        "summary": "Consultar un contenido",
        "description": "No surge de una viñeta explícita; es necesaria para poder editar o mostrar el\ncontenido. Si está en `draft`, solo lo puede ver el `creator` dueño del canal;\nsi está `published`, lo puede ver cualquiera.\n",
        "responses": {
          "200": {
            "description": "Detalle del contenido",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogItem"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "operationId": "updateCatalogItem",
        "tags": [
          "Content"
        ],
        "summary": "Editar metadata de un contenido existente",
        "description": "Requiere rol `creator`, dueño del contenido. Actualización parcial (RF-C2, viñeta 4).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogItemUpdateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contenido actualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogItem"
                }
              }
            }
          }
        }
      }
    },
    "/content/{contentId}/publish": {
      "x-rf-section": "RF-C3 — Publicación y visibilidad",
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        }
      ],
      "post": {
        "operationId": "publishCatalogItem",
        "tags": [
          "Content"
        ],
        "summary": "Publicar un contenido",
        "description": "Requiere rol `creator`. Pasa el estado a `published`.",
        "responses": {
          "200": {
            "description": "Contenido publicado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogItem"
                }
              }
            }
          }
        }
      }
    },
    "/content/{contentId}/unpublish": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        }
      ],
      "post": {
        "operationId": "unpublishCatalogItem",
        "tags": [
          "Content"
        ],
        "summary": "Despublicar u ocultar un contenido",
        "description": "Requiere rol `creator`. Pasa el estado a `unpublished`.",
        "responses": {
          "200": {
            "description": "Contenido despublicado"
          }
        }
      }
    },
    "/content/{contentId}/visibility": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        }
      ],
      "get": {
        "operationId": "getCatalogItemVisibility",
        "tags": [
          "Content"
        ],
        "summary": "Consultar si el contenido es visible para un espectador puntual",
        "description": "Paso central del escenario integrador (sección 13 del enunciado): se llama\nantes de reproducir un video. País y edad son datos del espectador que aporta\nquien llama (la identidad de usuario es una plataforma compartida, fuera de\neste bounded context). El estado de moderación y las restricciones activas\n(RF-C6) ya los tiene Catálogo internamente.\n",
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "CL"
            }
          },
          {
            "name": "age",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "example": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resultado de la verificación de visibilidad",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisibilityResult"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/playlists": {
      "x-rf-section": "RF-C4 — Playlists",
      "post": {
        "operationId": "createPlaylist",
        "tags": [
          "Playlists"
        ],
        "summary": "Crear una playlist",
        "description": "Requiere rol `creator`, dueño del `channelId` indicado.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaylistCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Playlist creada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Playlist"
                }
              }
            }
          }
        }
      }
    },
    "/playlists/{playlistId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/PlaylistIdParam"
        }
      ],
      "get": {
        "operationId": "getPlaylist",
        "tags": [
          "Playlists"
        ],
        "summary": "Consultar una playlist con su orden",
        "responses": {
          "200": {
            "description": "Detalle de la playlist con sus ítems en orden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Playlist"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
