    "/content/{contentId}/claims": {
      "x-rf-section": "RF-C5 — Derechos y reclamaciones",
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        }
      ],
      "post": {
        "operationId": "createClaim",
        "tags": [
          "Claims"
        ],
        "summary": "Registrar una reclamación de derechos sobre un contenido",
        "description": "Requiere rol `rights_entity`. Nace en estado `pending`.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClaimCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reclamación registrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Claim"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listClaims",
        "tags": [
          "Claims"
        ],
        "summary": "Listar las reclamaciones de un contenido",
        "description": "No surge de una viñeta explícita; es necesaria para poder revisarlas.",
        "responses": {
          "200": {
            "description": "Lista de reclamaciones (sin paginar; volumen acotado por contenido)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Claim"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/content/{contentId}/claims/{claimId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        },
        {
          "$ref": "#/components/parameters/ClaimIdParam"
        }
      ],
      "get": {
        "operationId": "getClaim",
        "tags": [
          "Claims"
        ],
        "summary": "Consultar el detalle de una reclamación",
        "responses": {
          "200": {
            "description": "Detalle de la reclamación",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Claim"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/content/{contentId}/claims/{claimId}/resolve": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        },
        {
          "$ref": "#/components/parameters/ClaimIdParam"
        }
      ],
      "post": {
        "operationId": "resolveClaim",
        "tags": [
          "Claims"
        ],
        "summary": "Resolver una reclamación (aceptar, disputar o retirar)",
        "description": "Requiere rol `creator` o un rol de moderación interna. Aceptar una reclamación\n**no** restringe el contenido automáticamente — eso es una acción aparte,\nexplícita, en `/content/{contentId}/restrictions` (RF-C6).\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClaimResolveInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reclamación resuelta",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Claim"
                }
              }
            }
          }
        }
      }
    },
    "/content/{contentId}/restrictions": {
      "x-rf-section": "RF-C6 — Políticas y restricciones",
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        }
      ],
      "post": {
        "operationId": "applyRestriction",
        "tags": [
          "Restrictions"
        ],
        "summary": "Aplicar una restricción de contenido",
        "description": "Requiere rol `creator` o moderación interna (RF-C6, viñeta 1). El contenido NO\ncambia su `status` general — la restricción se evalúa aparte en\n`/visibility`.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RestrictionCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Restricción aplicada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Restriction"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listRestrictions",
        "tags": [
          "Restrictions"
        ],
        "summary": "Consultar el historial y el estado actual de restricciones",
        "description": "Cubre RF-C6 viñetas 2 y 3 con un mismo listado: los registros sin\n`liftedAt` son las restricciones activas ahora mismo; los que sí tienen\n`liftedAt` son historial.\n",
        "responses": {
          "200": {
            "description": "Lista de restricciones (sin paginar; volumen acotado por contenido)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Restriction"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/content/{contentId}/restrictions/{restrictionId}/lift": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ContentIdParam"
        },
        {
          "$ref": "#/components/parameters/RestrictionIdParam"
        }
      ],
      "post": {
        "operationId": "liftRestriction",
        "tags": [
          "Restrictions"
        ],
        "summary": "Levantar una restricción",
        "description": "No se usa DELETE a propósito: borrar el registro perdería el historial que\npide RF-C6 viñeta 2. En cambio, se marca `liftedAt` y el registro se conserva.\nRequiere rol `creator` o moderación interna.\n",
        "responses": {
          "200": {
            "description": "Restricción levantada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Restriction"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT del actor autenticado (RNF-1). Roles relevantes en este contexto:\n- `creator`: dueño del canal/contenido (gestiona canal, edita, publica, arma playlists)\n- `viewer`: cualquier usuario que consulta contenido público\n- `rights_entity`: tercero autorizado para presentar reclamaciones de derechos\nEl rol requerido para cada operación se indica en su descripción.\n"
      }
    },
    "parameters": {
      "ChannelIdParam": {
        "name": "channelId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "ContentIdParam": {
        "name": "contentId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "PlaylistIdParam": {
        "name": "playlistId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "ClaimIdParam": {
        "name": "claimId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "RestrictionIdParam": {
        "name": "restrictionId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "PageParam": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "PageSizeParam": {
        "name": "pageSize",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "No autenticado o sin permisos para esta operación",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "El recurso solicitado no existe",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "CONTENT_NOT_FOUND"
          },
          "message": {
            "type": "string",
            "example": "El contenido solicitado no existe"
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          }
        }
      },
      "Channel": {
