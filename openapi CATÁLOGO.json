    {
      "name": "Playlists",
      "description": "Colecciones ordenadas de contenido"
    },
    {
      "name": "Claims",
      "description": "Reclamaciones de derechos"
    },
    {
      "name": "Restrictions",
      "description": "Restricciones de edad, geografía y monetización"
    }
  ],
